# Smrčak demo — RAG environment varijable
# Kopiraj u .env.local i popuni svoje ključeve.
# .env.local je u .gitignore-u i NIKAD se ne commit-uje.

# OpenAI — za embeddings (text-embedding-3-small, 1536 dim)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Pinecone — vector database (rag-msp-smrcak index, 1536 dim, cosine, AWS us-east-1 serverless)
# https://app.pinecone.io
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=rag-msp-smrcak

# Anthropic — Claude Sonnet 4.5 za RAG odgovore
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
